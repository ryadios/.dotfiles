{
    "format_on_save": "off",
    "edit_predictions": {
        "provider": "copilot",
    },
    "context_servers": {
        "mcp-server-context7": {
            "enabled": true,
            "settings": {
                "context7_api_key": "ctx7sk-f0c39a70-de7b-429b-96cc-2fe3c6b98476",
            },
        },
    },
    "disable_ai": false,
    "agent": {
        "play_sound_when_agent_done": true,
        "default_model": {
            "provider": "google",
            "model": "gemini-3-pro-preview",
        },
    },
    "show_edit_predictions": false,
    "theme": "Cursor Dark",
    "project_panel": {
        "dock": "left",
        "default_width": 280,
        "auto_reveal_entries": false,
    },
    "toolbar": {
        "quick_actions": false,
        "selections_menu": false,
    },
    "vim_mode": true,
    "ui_font_size": 16,
    "buffer_font_size": 16,
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "base_keymap": "VSCode",
    "relative_line_numbers": "enabled",
    "cursor_blink": true,
    "tab_size": 4,
    "telemetry": {
        "diagnostics": false,
        "metrics": false,
    },
    "indent_guides": {
        "enabled": true,
        "coloring": "indent_aware",
    },
    "languages": {
        "C++": {
            "format_on_save": "on",
            "language_servers": ["clangd"],
        },
        "TypeScript": {
            "tab_size": 4,
        },
    },
    "file_scan_exclusions": [
        "**/.git",
        "**/node_modules",
        "**/target",
        "**/.next",
        "**/.nuxt",
        "**/dist",
        "**/build",
    ],
    "git": {
        "git_gutter": "tracked_files",
        "inline_blame": {
            "enabled": true,
            "delay_ms": 800,
        },
        "gutter_debounce": 300,
    },
    "which_key": {
        "enabled": true,
        "delay_ms": 200,
    },
    "icon_theme": {
        "mode": "system",
        "dark": "Material Icon Theme",
        "light": "Material Icon Theme",
    },
    "show_completions_on_input": true,
    "lsp_document_colors": "background",
    "soft_wrap": "editor_width",
}
